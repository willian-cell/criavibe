# CriaVibe .env example
# Database (optional if using MYSQL_URL)
MYSQL_URL=

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_PUBLIC_URL=

# Redis (fila de processamento)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Worker settings
WORKER_QUEUE_NAME=image_jobs
WORKER_POLL_TIMEOUT=5

# Forçar uploads diretos (desabilita api/fotos/upload.php quando 1)
FORCE_DIRECT_UPLOAD=0
