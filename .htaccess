# .htaccess — CriaVibe PHP Edition

Options -Indexes

# As configurações de PHP foram removidas daqui porque
# a Hostinger bloqueia a diretiva php_value no .htaccess e retorna Erro 500!
# Você deve alterar os limites de Upload direto no Painel da Hostinger (Configurações do PHP).

# ── Protect sensitive files ────────────────────────────────────
<Files ".env">
  Order allow,deny
  Deny from all
</Files>
<Files "*.sql">
  Order allow,deny
  Deny from all
</Files>
<Files "*.md">
  Order allow,deny
  Deny from all
</Files>

# ── Protect uploads dir from PHP execution ─────────────────────
<Directory "uploads">
  php_flag engine off
  Options -ExecCGI
  AddType text/plain .php .php3 .phtml
</Directory>

# ── Routing (SPA-like) ─────────────────────────────────────────
RewriteEngine On

# Allow direct access to real files/directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Serve index.html for anything else at root
# (API routes handled directly by PHP files)
